<Window x:Class="LanDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LanDesk - Remote Desktop" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Icon="landesk.ico"
        Loaded="MainWindow_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="LanDesk" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" Foreground="Gray" Margin="10,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="ApprovalHintText" Text="" Foreground="DarkGreen" FontStyle="Italic" Margin="0,2,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
            </StackPanel>
            
            <!-- Local Device Info -->
            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center">
                <Border Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="1" 
                        CornerRadius="5" Padding="15,8" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Device: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="LocalDeviceNameText" Text="Unknown" 
                                   FontSize="14" FontWeight="Bold" Foreground="#0066CC" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="1" 
                        CornerRadius="5" Padding="15,8" Margin="0,0,0,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Your ID: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="LocalPairingCodeText" Text="000-000-000" 
                                   FontSize="18" FontWeight="Bold" Foreground="#0066CC" 
                                   VerticalAlignment="Center" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
                <Border Background="#E8F4F8" BorderBrush="#CCCCCC" BorderThickness="1" 
                        CornerRadius="5" Padding="15,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Your IP: " VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                        <TextBlock x:Name="LocalIpAddressText" Text="0.0.0.0" 
                                   FontSize="14" FontWeight="Bold" Foreground="#006600" 
                                   VerticalAlignment="Center" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Device List -->
        <GroupBox Grid.Row="1" Header="Discovered Devices" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5" HorizontalAlignment="Right">
                    <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" Margin="5,0" Padding="10,5"/>
                    <Button x:Name="StartDiscoveryButton" Content="Start Discovery" Click="StartDiscoveryButton_Click" Margin="5,0" Padding="10,5"/>
                    <Button x:Name="StopDiscoveryButton" Content="Stop Discovery" Click="StopDiscoveryButton_Click" Margin="5,0" Padding="10,5" IsEnabled="False"/>
                </StackPanel>

                <!-- Device ListView -->
                <ListView x:Name="DeviceListView" Grid.Row="1" Margin="5" SelectionChanged="DeviceListView_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Device Name" Width="180" DisplayMemberBinding="{Binding DeviceName}"/>
                            <GridViewColumn Header="Code" Width="120" DisplayMemberBinding="{Binding PairingCode}"/>
                            <GridViewColumn Header="IP Address" Width="130" DisplayMemberBinding="{Binding IpAddress}"/>
                            <GridViewColumn Header="OS" Width="180" DisplayMemberBinding="{Binding OperatingSystem}"/>
                            <GridViewColumn Header="Status" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Online"/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                            <Setter Property="Text" Value="Offline"/>
                                                            <Setter Property="Foreground" Value="Red"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Last Seen" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LastSeen, StringFormat='{}{0:HH:mm:ss}'}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>

        <!-- Connect by Code, Device Name, or IP Section -->
        <GroupBox Grid.Row="2" Header="Connect by Code, Device Name, or IP Address" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PairingCodeTextBox" Grid.Column="0" 
                             FontSize="16" FontFamily="Consolas" Padding="10,5" Margin="5"
                             TextChanged="PairingCodeTextBox_TextChanged"
                             VerticalContentAlignment="Center"
                             ToolTip="Enter pairing code (e.g., 123-456-789), device name (e.g., DESKTOP-ABC123), or IP address (e.g., 192.168.1.100)">
                    </TextBox>
                    <Button x:Name="ConnectByCodeButton" Grid.Column="1" Content="Connect" 
                            Click="ConnectByCodeButton_Click" Padding="20,8" Margin="5" 
                            IsEnabled="False" FontSize="14" FontWeight="Bold"
                            ToolTip="Connect using pairing code, device name, or IP address"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="Enter pairing code (123-456-789), device name (DESKTOP-ABC123), or IP address (192.168.1.100)" 
                           Foreground="Gray" FontSize="11" Margin="5,0,5,5" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- Connect by IP/Domain Section -->
        <GroupBox Grid.Row="3" Header="Connect by IP Address or Domain Name (Direct Connection)" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="IpAddressTextBox" Grid.Column="0" 
                             FontSize="14" FontFamily="Consolas" Padding="10,5" Margin="5"
                             TextChanged="IpAddressTextBox_TextChanged"
                             VerticalContentAlignment="Center"
                             ToolTip="Enter IP address (e.g., 192.168.1.100) or domain name (e.g., computer.example.com)">
                        <TextBox.Text>
                            <Binding Path="Text" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <DataErrorValidationRule/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>
                    <Button x:Name="ConnectByIpButton" Grid.Column="1" Content="Connect Directly" 
                            Click="ConnectByIpButton_Click" Padding="20,8" Margin="5" 
                            IsEnabled="False" FontSize="14" FontWeight="Bold"
                            ToolTip="Connect directly to IP address or domain name (no server required)"/>
                </Grid>
                <TextBlock Grid.Row="1" Text="Enter IP address (e.g., 192.168.1.100) or domain name (e.g., computer.example.com)" 
                           Foreground="Gray" FontSize="11" Margin="5,0,5,5" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ViewLogsButton" Content="View Logs" Click="ViewLogsButton_Click" 
                    Padding="15,8" Margin="5,0" ToolTip="Open log folder"/>
            <Button x:Name="ConnectButton" Content="Connect to Selected" Click="ConnectButton_Click" 
                    Padding="20,8" Margin="5,0" IsEnabled="False" FontSize="14" FontWeight="Bold"/>
            <Button x:Name="ExitButton" Content="Exit" Click="ExitButton_Click" 
                    Padding="20,8" Margin="5,0"/>
        </StackPanel>
    </Grid>
</Window>
